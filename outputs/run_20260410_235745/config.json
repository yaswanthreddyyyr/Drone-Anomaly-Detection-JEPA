{
  "data": {
    "raw_dir": "data/drone_temparing_dataset_v2",
    "processed_dir": "processed_data"
  },
  "chunking": {
    "chunk_size": 20,
    "stride": 10,
    "min_chunk_size": 15
  },
  "features": {
    "base_features": [
      "latitude",
      "longitude",
      "altitude",
      "speed",
      "heading"
    ],
    "derived_features": [
      "delta_lat",
      "delta_lon",
      "delta_alt",
      "acceleration",
      "angular_velocity",
      "distance"
    ],
    "use_derived": true
  },
  "normalization": {
    "method": "robust",
    "clip_outliers": true,
    "clip_percentile": [
      1,
      99
    ]
  },
  "splits": {
    "train": {
      "profiles": [
        "balanced"
      ],
      "replicates": [
        "rep_00",
        "rep_01"
      ],
      "use_only_normal": false,
      "extract_normal_from_anomaly": true
    },
    "validation": {
      "profiles": [
        "balanced"
      ],
      "replicates": [
        "rep_02"
      ]
    },
    "test": {
      "balanced": {
        "profiles": [
          "balanced"
        ],
        "replicates": [
          "rep_03"
        ]
      },
      "strong": {
        "profiles": [
          "strong"
        ],
        "replicates": [
          "rep_00",
          "rep_01",
          "rep_02",
          "rep_03"
        ]
      },
      "subtle": {
        "profiles": [
          "subtle"
        ],
        "replicates": [
          "rep_00",
          "rep_01",
          "rep_02",
          "rep_03"
        ]
      }
    }
  },
  "model": {
    "embedding_dim": 256,
    "encoder_hidden": [
      512,
      256,
      256
    ],
    "predictor_hidden": [
      256,
      256
    ],
    "dropout": 0.1
  },
  "masking": {
    "adaptive": true,
    "min_mask_ratio": 0.2,
    "max_mask_ratio": 0.5,
    "fixed_mask_ratio": 0.3,
    "entropy_window": 5,
    "entropy_features": [
      "speed",
      "heading",
      "altitude"
    ]
  },
  "training": {
    "batch_size": 128,
    "epochs": 2,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "scheduler": "cosine",
    "warmup_epochs": 5
  },
  "isolation_forest": {
    "n_estimators": 100,
    "contamination": 0.05,
    "max_samples": "auto",
    "random_state": 42
  },
  "seed": 42,
  "num_workers": 4,
  "device": "auto"
}